# --- Backend (Render / local) ---
REDIS_URL=redis://redis:6379/0
CORS_ORIGINS=http://localhost:3000,https://your-frontend.vercel.app
WHISPER_MODEL_SIZE=small
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8
NLLB_MODEL_NAME=facebook/nllb-200-distilled-600M
MAX_VIDEO_SECONDS=1800
JOB_RESULT_TTL=86400
AUDIO_TMP_DIR=/tmp/ytt_audio
# Runs the RQ worker as a background thread inside the web process so a
# single free-tier instance handles both HTTP + job processing. Set to
# false if you deploy a separate always-on worker service instead.
RUN_WORKER_IN_PROCESS=true
# NLLB-200 needs ~2.4GB RAM; leave disabled on free tiers (Whisper's
# translate task already covers non-English audio -> English text).
ENABLE_NLLB_TRANSLATION=false

# --- Frontend (Vercel / local) ---
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
